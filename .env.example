# Copy to .env on the server and fill in real values. Never commit .env.

# --- Server ---
PORT=5000
NODE_ENV=production

# --- Enquiry storage ---
# Enquiries are saved as .txt files (one per enquiry). Default: <app>/data/enquiries
# ENQUIRIES_DIR=/home/ubuntu/niytri-enquiries

# --- Microsoft 365 email (Graph API, client-credentials) ---
# From your Entra ID app registration (see DEPLOYMENT.md step 4).
# Leave empty to skip emails; enquiries are still saved to txt files.
M365_TENANT_ID=
M365_CLIENT_ID=
M365_CLIENT_SECRET=
# Mailbox the emails are sent from
M365_SENDER=admin@niytri.com
# Comma-separated recipients for new-enquiry notifications
ENQUIRY_NOTIFY_TO=amit@niytri.com,ashish@niytri.com

# --- Admin ---
# Random secret; required to read enquiries via GET /api/enquiries (X-Api-Key header)
ADMIN_API_KEY=
